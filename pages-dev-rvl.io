        text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
      }
      @keyframes shine {
        0% { opacity: 0.8; }
        50% { opacity: 1; }
        100% { opacity: 0.8; }
      }
      .footer {
        text-align: center;
        margin-top: 20px;
        font-size: 14px;
        color: #888;
      }
      .footer a {
        color: var(--primary-color);
